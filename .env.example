# ── Database ────────────────────────────────────────────────
DATABASE_URL="postgresql://aion:aion@localhost:5432/aion?schema=public"

# ── API ─────────────────────────────────────────────────────
API_PORT=4000
API_BASE_URL="http://localhost:4000"
JWT_SECRET="change-me-in-prod"

# ── Web ─────────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL="http://localhost:4000"
WEB_PORT=3000

# ── Auth (Auth.js / Google OAuth) ───────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── Stripe (core/billing → entitlements) ────────────────────
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# ── AI (core/ai — Claude default, provider-agnostic) ────────
AI_PROVIDER="anthropic"
ANTHROPIC_API_KEY=""

# ── Notifications ───────────────────────────────────────────
SMTP_URL=""
TWILIO_ACCOUNT_SID=""
